{
  "name": "phantom-ai-v3",
  "version": "3.0.0",
  "description": "PHANTOM AI v3 — Enterprise Autonomous Pentest Platform",
  "author": "PHANTOM Security",
  "license": "MIT",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "react": "react-scripts start",
    "build": "GENERATE_SOURCEMAP=false react-scripts build",
    "electron-dev": "ELECTRON_START_URL=http://localhost:3000 electron .",
    "start": "concurrently \"npm run react\" \"wait-on http://localhost:3000 && sleep 1 && npm run electron-dev\"",
    "dist": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder --mac --win",
    "scan": "python3 backend/cli.py scan",
    "train": "python3 backend/cli.py train",
    "phantom": "python3 backend/cli.py",
    "status": "python3 backend/cli.py status"
  },
  "build": {
    "extends": null,
    "appId": "com.phantom.ai.v3",
    "productName": "Phantom AI",
    "npmRebuild": false,
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "backend/**/*",
      "node_modules/**/*",
      "!node_modules/better-sqlite3{,/**}",
      "!**/._*",
      "!**/__pycache__/**"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": null,
      "hardenedRuntime": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Phantom AI v3",
      "contents": [
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 220,
          "type": "file"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "better-sqlite3": "9.4.3",
    "electron-log": "5.1.1",
    "electron-store": "8.1.0",
    "express": "^4.22.1",
    "node-forge": "^1.3.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "concurrently": "8.2.2",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-scripts": "5.0.1",
    "recharts": "2.12.2",
    "wait-on": "7.2.0"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      "last 1 electron version"
    ],
    "development": [
      "last 1 electron version"
    ]
  }
}
